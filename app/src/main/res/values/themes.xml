<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MoneyLogs" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.MoneyLogs" parent="Base.Theme.MoneyLogs">
        <item name="android:windowBackground">@color/bg_light</item>
    </style>

    <!-- Activity 테마: splash가 fade-out 되기 전까지 라이트 배경을 강제하여
         다크모드 사용자에게도 검은 깜빡임 없이 머니로그 디자인 splash가 보이도록 함.
         loadingOverlay가 화면을 덮은 뒤 fade-out으로 webView가 드러나면 페이지 자체의
         다크 처리는 웹 측 next-themes가 담당. -->
    <style name="Theme.MoneyLogs.Splash" parent="Theme.MoneyLogs">
        <item name="android:windowBackground">@color/bg_light</item>
    </style>
</resources>
