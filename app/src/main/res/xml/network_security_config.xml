<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- moneylogs.vercel.app 만 허용, 평문 HTTP 차단 -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">moneylogs.vercel.app</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
